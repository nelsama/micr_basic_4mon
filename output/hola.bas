10 REM HOLA NOMBRE - RAM SEGURA ($2D00)
15 PRINT "NOMBRE? ";
20 P = 11520 : L = 0
30 RX K
40 IF K = 13 THEN 130
50 IF K < 32 THEN 30
60 POKE P, K
70 TX K
80 P = P + 1
90 L = L + 1
100 GOTO 30
110 PRINT "HOLA"
120 P = 11520
130 F = 11520 + L
140 IF P = F THEN 180
150 C = PEEK(P)
160 TX C
170 P = P + 1 : GOTO 140
180 PRINT
190 STOP