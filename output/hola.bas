10 REM LED LIGHT SHOW + SID POLIFONICO + UART DEBUG
15 REM PRESIONA 'C' PARA DETENER
20 LET M = 192
30 GOSUB 1000
40 GOTO 100
100 REM BUCLE PRINCIPAL DE PATRONES
110 GOSUB 200
120 GOSUB 400
130 GOSUB 600
140 GOSUB 800
150 GOTO 100
200 REM PATRON 1: CHASE (IZQ A DER)
201 PRINT "=== CHASE ==="
210 LET P = 1
220 FOR I = 0 TO 5
230 LET V = M + 63 - P
235 LEDS V                 : REM FIX: ACTUALIZA LEDs
240 LET F = 12000 + P * 1500
250 LET D = 50
260 GOSUB 3500
270 LET P = P * 2
280 NEXT I
290 RETURN
400 REM PATRON 2: KNIGHT RIDER (REBOTE)
401 PRINT "=== KNIGHT RIDER ==="
410 LET P = 1
420 FOR I = 0 TO 5
430 LET V = M + 63 - P
435 LEDS V                 : REM FIX: ACTUALIZA LEDs
440 LET F = 14000 + P * 1200
450 LET D = 55
460 GOSUB 3500
470 LET P = P * 2
480 NEXT I
490 LET P = 16
500 FOR I = 0 TO 4
510 LET V = M + 63 - P
515 LEDS V                 : REM FIX: ACTUALIZA LEDs
520 LET F = 26000 - P * 800
530 LET D = 55
540 GOSUB 3500
550 LET P = P / 2
560 NEXT I
570 RETURN
600 REM PATRON 3: CONTEO BINARIO (0-63)
601 PRINT "=== BINARIO ==="
610 FOR C = 0 TO 63
620 LET V = M + 63 - C
630 LEDS V
640 LET F = 10000 + C * 200
650 LET D = 35
660 GOSUB 3500
670 WAIT 25
680 GET K : IF K=67 THEN STOP
690 NEXT C
700 RETURN
800 REM PATRON 4: PARPADEO Y ALTERNADO
801 PRINT "=== PARPADEO ==="
810 FOR I = 0 TO 4
820 LEDS 192
830 LET F = 11000
840 LET D = 60
850 GOSUB 3500
860 WAIT 60
870 GET K : IF K=67 THEN STOP
880 LEDS 255
890 LET F = 22000
900 LET D = 60
910 GOSUB 3500
920 WAIT 60
930 GET K : IF K=67 THEN STOP
940 NEXT I
950 RETURN
1000 REM INIT SID (3 VOCES + REGISTROS CORREGIDOS)
1010 PRINT "INICIANDO SHOW POLIFONICO..."
1020 POKE 54296, 15        : REM VOL MAX ($D418)
1030 POKE 54277, 8         : REM V1 AD ($D405)
1040 POKE 54278, 128       : REM V1 SR ($D406)
1050 POKE 54284, 8         : REM V2 AD ($D40C)
1060 POKE 54285, 128       : REM V2 SR ($D40D)
1070 POKE 54291, 8         : REM V3 AD ($D413)
1080 POKE 54292, 128       : REM V3 SR ($D414)
1090 RETURN
3500 REM SUB: SID POLIFONICO (3 VOCES SIMULTANEAS)
3510 LET X = F / 2         : REM V2 (OCTABA INFERIOR)
3520 LET Y = F - 6000      : REM V3 (QUINTA/ARMONIA)
3530 IF Y < 8000 THEN LET Y = 8000
3540 POKE 54272, F % 256   : REM V1 FREQ LO ($D400)
3550 POKE 54273, F / 256   : REM V1 FREQ HI ($D401)
3560 POKE 54276, 17        : REM V1 CTRL: TRI+GATE ON ($D404)
3570 POKE 54279, X % 256   : REM V2 FREQ LO ($D407)
3580 POKE 54280, X / 256   : REM V2 FREQ HI ($D408)
3590 POKE 54283, 33        : REM V2 CTRL: SAW+GATE ON ($D40B)
3600 POKE 54286, Y % 256   : REM V3 FREQ LO ($D40E)
3610 POKE 54287, Y / 256   : REM V3 FREQ HI ($D40F)
3620 POKE 54290, 9         : REM V3 CTRL: TRI+NOISE+GATE ON ($D412)
3630 WAIT D                : REM DURACION
3640 POKE 54276, 16        : REM V1 GATE OFF
3650 POKE 54283, 32        : REM V2 GATE OFF
3660 POKE 54290, 8         : REM V3 GATE OFF
3670 RETURN